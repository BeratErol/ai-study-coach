                    <p className="font-semibold text-gray-900 text-sm truncate">{lesson.name}</p>
                    <p className="text-xs text-gray-500 mb-1.5">{done} / {total} konu</p>
                    <div className="h-1.5 bg-gray-100 rounded-full overflow-hidden">
