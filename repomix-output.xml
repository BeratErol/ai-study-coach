            var lesson = await _context.Lessons
                .FirstOrDefaultAsync(l => l.Id == lessonId && l.UserId == userId);

            if (lesson == null) return false;

            _context.Lessons.Remove(lesson);
            await _context.SaveChangesAsync();

            return true;
        }
    }
