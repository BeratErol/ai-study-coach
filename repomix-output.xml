                .toList() ??
            [],
        strongSubjects: (json['strongSubjects'] as List<dynamic>?)
                ?.map((e) => e as String)
                .toList() ??
            [],
        weakSubjects: (json['weakSubjects'] as List<dynamic>?)
                ?.map((e) => e as String)
                .toList() ??
            [],
