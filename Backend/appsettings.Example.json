{
  "_README": "Bu dosyayı 'appsettings.Development.json' olarak kopyalayıp gerçek değerleri doldurun. Development.json .gitignore'dadır, commit edilmez. ASP.NET Core Development environment'ta otomatik yüklenir.",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=aistudycoach;Username=postgres;Password=YOUR_DB_PASSWORD"
  },
  "JwtSettings": {
    "Key": "YOUR_256_BIT_HEX_KEY_HERE",
    "Issuer": "AiStudyCoachAPI",
    "Audience": "AiStudyCoachUsers",
    "DurationInMinutes": 1440
  },
  "GeminiApiKey": "YOUR_GEMINI_API_KEY"
}
